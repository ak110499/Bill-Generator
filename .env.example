# VITE_OPENAI_API_KEY: Required for OpenAI API calls from the browser.
# For local development, copy this file to .env.local and set your key.
# Note: For production, use a backend proxy so your key is not exposed to clients.
VITE_OPENAI_API_KEY="MY_OPENAI_API_KEY"

# OPENAI_API_KEY: Optional fallback when using non-Vite runtime injection.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# APP_URL: Optional base URL where this app is hosted.
APP_URL="MY_APP_URL"
